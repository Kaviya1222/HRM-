APP_NAME=HRM API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=hrm_db
MYSQL_USER=root
MYSQL_PASSWORD=root
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/hrm_db?charset=utf8mb4
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080
AUTO_BOOTSTRAP=true
SEED_DEMO_DATA=true
INITIAL_SUPER_ADMIN_EMAIL=superadmin@hrm.local
INITIAL_SUPER_ADMIN_PASSWORD=SuperAdmin@123
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=HRM
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=15
